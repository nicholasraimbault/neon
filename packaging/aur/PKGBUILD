# Maintainer: Nicholas Raimbault <nicholasraimbault@users.noreply.github.com>
pkgname=neon-drm
pkgver=1.0.0
pkgrel=1
pkgdesc="Fix DRM playback in Chromium-based browsers on Linux"
arch=('x86_64')
url="https://github.com/nicholasraimbault/neon"
license=('MIT')
depends=('python3' 'curl' 'unzip')
makedepends=('go' 'libayatana-appindicator3')
optdepends=(
  'systemd: auto-patch daemon'
  'polkit: graphical privilege escalation for tray app'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "neon-$pkgver/linux-app"
  go build -o neon-tray .
}

package() {
  cd "neon-$pkgver"

  # Core scripts
  install -Dm755 fix-drm.sh "$pkgdir/usr/lib/neon/fix-drm.sh"
  install -Dm755 download-widevine.sh "$pkgdir/usr/lib/neon/download-widevine.sh"
  install -Dm755 install.sh "$pkgdir/usr/lib/neon/install.sh"
  install -Dm755 uninstall.sh "$pkgdir/usr/lib/neon/uninstall.sh"

  # CLI wrapper scripts
  install -d "$pkgdir/usr/bin"
  for cmd in install uninstall; do
    cat > "$pkgdir/usr/bin/neon-$cmd" << EOF
#!/bin/bash
exec /usr/lib/neon/$cmd.sh "\$@"
EOF
    chmod 755 "$pkgdir/usr/bin/neon-$cmd"
  done

  cat > "$pkgdir/usr/bin/neon-patch" << 'EOF'
#!/bin/bash
exec /usr/lib/neon/fix-drm.sh "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/neon-patch"

  cat > "$pkgdir/usr/bin/neon-update-widevine" << 'EOF'
#!/bin/bash
exec /usr/lib/neon/download-widevine.sh "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/neon-update-widevine"

  # Tray app
  install -Dm755 linux-app/neon-tray "$pkgdir/usr/bin/neon-tray"

  # Desktop entry
  install -Dm644 linux-app/neon.desktop "$pkgdir/usr/share/applications/neon.desktop"

  # Polkit policy
  install -Dm644 linux-app/com.neon.fix-drm.policy "$pkgdir/usr/share/polkit-1/actions/com.neon.fix-drm.policy"

  # systemd units
  install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/neon-fix-drm.path" << 'EOF'
[Unit]
Description=Neon: Watch browsers for updates

[Path]
PathChanged=/opt/helium-browser-bin
PathChanged=/opt/chromium.org/thorium
PathChanged=/opt/thorium-browser
PathChanged=/usr/lib/chromium
PathChanged=/usr/lib64/chromium
PathChanged=/usr/lib/chromium-browser

[Install]
WantedBy=multi-user.target
EOF

  install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/system/neon-fix-drm.service" << EOF
[Unit]
Description=Neon: Patch WidevineCdm into browsers

[Service]
Type=oneshot
ExecStartPre=/bin/sleep 5
ExecStart=/usr/lib/neon/fix-drm.sh
StandardOutput=journal
StandardError=journal
EOF

  # License
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
